<Keyboard xmlns:limehd="http://schemas.android.com/apk/res-auto"
    limehd:horizontalGap="@dimen/key_horizontal_gap_material3"
    limehd:keyHeight="@dimen/key_height_material3"
    limehd:keyWidth="10%p"
    limehd:verticalGap="@dimen/key_vertical_gap_material3">

    <Row>
        <Key
            limehd:keyEdgeFlags="left"
            limehd:keyLabel="【" />
        <Key limehd:keyLabel="〈" />
        <Key limehd:keyLabel="『" />
        <Key limehd:keyLabel="「" />
        <Key limehd:keyLabel="？" />
        <Key limehd:keyLabel="：" />
        <Key limehd:keyLabel="．" />
        <Key limehd:keyLabel="◎" />
        <Key limehd:keyLabel="＠" />
        <Key
            limehd:keyEdgeFlags="right"
            limehd:keyLabel="☑" />
    </Row>

    <Row>
        <Key
            limehd:keyEdgeFlags="left"
            limehd:keyLabel="】" />
        <Key limehd:keyLabel="〉" />
        <Key limehd:keyLabel="』" />
        <Key limehd:keyLabel="」" />
        <Key limehd:keyLabel="！" />
        <Key limehd:keyLabel="；" />
        <Key limehd:keyLabel="、" />
        <Key limehd:keyLabel="☒" />
        <Key limehd:keyLabel="　" />
        <Key
            limehd:keyEdgeFlags="right"
            limehd:keyLabel="✔" />
    </Row>

    <Row>
        <Key
            limehd:codes="-15"
            limehd:isModifier="true"
            limehd:keyEdgeFlags="left"
            limehd:keyLabel="3/3"
            limehd:keyWidth="15%p" />
        <Key limehd:keyLabel="○" />
        <Key limehd:keyLabel="●" />
        <Key limehd:keyLabel="➤" />
        <Key limehd:keyLabel="█" />
        <Key limehd:keyLabel="≠" />
        <Key limehd:keyLabel="≒" />
        <Key limehd:keyLabel="㊣" />
        <Key
            limehd:codes="-5"
            limehd:isModifier="true"
            limehd:isRepeatable="true"
            limehd:keyEdgeFlags="right"
            limehd:keyIcon="@drawable/sym_keyboard_delete_material3"
            limehd:keyWidth="15%p" />
    </Row>

    <Row limehd:rowEdgeFlags="bottom">
        <Key
            limehd:codes="-2"
            limehd:isModifier="true"
            limehd:keyEdgeFlags="left"
            limehd:keyLabel="EN"
            limehd:keyWidth="10%p" />
        <Key
            limehd:codes="-10"
            limehd:isModifier="true"
            limehd:keyLabel="中"
            limehd:keyWidth="10%p" />
        <Key
            limehd:codes="-100"
            limehd:keyIcon="@drawable/ic_emoji_vector"
            limehd:keyWidth="10%p" />
        <Key
            limehd:codes="32"
            limehd:iconPreview="@drawable/sym_keyboard_feedback_space"
            limehd:isRepeatable="true"
            limehd:keyIcon="@drawable/sym_flat_keyboard_space"
            limehd:keyWidth="35%p" />
        <Key
            limehd:keyLabel="，"
            limehd:keyWidth="10%p" />
        <Key
            limehd:keyLabel="。"
            limehd:keyWidth="10%p" />
        <Key
            limehd:codes="10"
            limehd:isModifier="true"
            limehd:keyEdgeFlags="right"
            limehd:keyIcon="@drawable/sym_keyboard_return_material3"
            limehd:keyWidth="15%p" />
    </Row>
</Keyboard>
