<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="5dp">

    <!-- Top Bar: Keyboard Selector -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageImKeyboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/manage_im_keyboard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Toggle Button Logic -->
    <!-- Keeping generic ToggleButton ID for compatibility or replacing if refactoring Java simultaneously -->
    <!-- The Java code uses ToggleButton toggleManageIm. We can keep it or swap to MaterialToggleGroup -->
    <!-- For minimal Java breakage, let's keep the ToggleButton but style it hidden if we use a better UI, 
         OR just use the ToggleButton for now but constrained. -->
    
    <ToggleButton
        android:id="@+id/toggleManageIm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:textOff="@string/manage_im_root"
        android:textOn="@string/manage_im_word"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnManageImKeyboard" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/edtManageImSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        android:hint="@string/manage_im_search"
        app:layout_constraintBottom_toBottomOf="@id/toggleManageIm"
        app:layout_constraintEnd_toStartOf="@id/btnManageImSearch"
        app:layout_constraintStart_toEndOf="@id/toggleManageIm"
        app:layout_constraintTop_toTopOf="@id/toggleManageIm" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageImSearch"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/manage_im_search"
        app:layout_constraintBottom_toBottomOf="@id/toggleManageIm"
        app:layout_constraintEnd_toStartOf="@id/btnManageImAdd"
        app:layout_constraintTop_toTopOf="@id/toggleManageIm" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageImAdd"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="@string/manage_im_add"
        app:layout_constraintBottom_toBottomOf="@id/toggleManageIm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/toggleManageIm" />

    <TextView
        android:id="@+id/txtNavigationInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="0-0 of 0"
        android:textAppearance="?android:attr/textAppearanceSmall"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toggleManageIm" />

    <!-- RecyclerView (replacing GridView) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/gridManageIm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        app:layout_constraintBottom_toTopOf="@id/btnManageImPrevious"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtNavigationInfo" />

    <!-- Navigation Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageImPrevious"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:text="@string/manage_im_previous"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnManageImNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManageImNext"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:text="@string/manage_im_next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnManageImPrevious"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>