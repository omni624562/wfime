<nan.toload.main.hd.candidate.CandidateInInputViewContainer xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Gboard-style candidate bar: dark, compact, full width -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="36dp"
        android:background="#2B2B2B"
        android:orientation="horizontal">

        <nan.toload.main.hd.candidate.CandidateView
            android:id="@+id/candidatesView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical" />

        <!-- Small expand button on the right -->
        <ImageButton
            android:id="@+id/candidate_right"
            android:layout_width="40dp"
            android:layout_height="fill_parent"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/more_cand"
            android:src="@drawable/ic_suggest_expander"
            android:visibility="gone" />

    </LinearLayout>

    <nan.toload.main.hd.keyboard.LIMEKeyboardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/keyboard"
        style="?attr/LIMEKeyboardLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:keyTextSize="@dimen/key_text_size"
        android:labelTextSize="@dimen/label_text_size"
        android:popupLayout="@layout/keyboard_popup" />
</nan.toload.main.hd.candidate.CandidateInInputViewContainer>